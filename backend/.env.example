# Port the server will listen on
PORT=3000

# PostgreSQL connection URL for Prisma
DATABASE_URL=postgresql://user:password@localhost:5432/athletics_db?schema=public

# Secret key for signing admin JWT tokens
JWT_SECRET=your_jwt_secret_here

# Optional: seed admin credentials (defaults: admin@example.com / Admin1234!)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=Admin1234!
